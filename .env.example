# ── Documentation Source ───────────────────────────────────────────────────────
DOCS_URL=https://your-docs-url-here.com

# ── User Agent ─────────────────────────────────────────────────────────────────
USER_AGENT=cmdfinder-mcp/2.0

# ── Embedding Model ────────────────────────────────────────────────────────────
# Provider options: sentence_transformers | openai | ollama
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# OpenAI embeddings (set EMBEDDING_PROVIDER=openai to use)
# OPENAI_API_KEY=sk-proj-...
# EMBEDDING_MODEL=text-embedding-3-small

# Ollama embeddings (set EMBEDDING_PROVIDER=ollama to use)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── LLM Configuration ──────────────────────────────────────────────────────────
# Provider options: anthropic | openai | ollama
# Note: When used via Claude Desktop, Claude is the LLM agent.
# These settings apply when using a non-Claude MCP client.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Anthropic LLM
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI LLM (set LLM_PROVIDER=openai to use)
# OPENAI_LLM_API_KEY=sk-proj-...

# Ollama LLM (set LLM_PROVIDER=ollama to use, local model, no API key needed)
# OLLAMA_LLM_BASE_URL=http://localhost:11434
# OLLAMA_LLM_MODEL=llama3.2

# ── FAISS Index ────────────────────────────────────────────────────────────────
FAISS_INDEX_DIR=faiss_index
FAISS_TOP_K=5

# ── Chunking ───────────────────────────────────────────────────────────────────
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# ── Server ─────────────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=9008
